{
  "LegacyInfrastructure": {
    "EnableDetailedErrors": true,
    "CommandTimeoutSeconds": 60
  },
  "LegacyAuth": {
    "HeaderName": "X-Api-Token",
    "TokenValidPeriodHours": 24,
    "EnablePayloadTokenFallback": true
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
