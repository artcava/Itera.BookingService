{
  "ConnectionStrings": {
    "LegacyMain": ""
  },
  "Infrastructure": {
    "EnableDetailedErrors": false,
    "CommandTimeoutSeconds": 30
  },
  "Auth": {
    "HeaderName": "X-Api-Token",
    "TokenValidPeriodHours": 24,
    "EnablePayloadTokenFallback": true
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
